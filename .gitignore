# ======================================================================
# Datasets (raw data must NEVER be committed — downloaded at runtime)
# ======================================================================
dataset/
data/datasets/
*.idx
*.idx1-ubyte
*.idx3-ubyte
*-ubyte
*-ubyte.gz

# ======================================================================
# Pretrained model cache (downloaded from HuggingFace at runtime)
# ======================================================================
pretrained/
.cache/
.cache/huggingface/
.huggingface/

# ======================================================================
# Model checkpoints & serialized weights (large binaries)
# ======================================================================
*.pth
*.pt
*.ckpt
*.pkl
*.pickle
*.onnx
*.pb
*.h5
*.hdf5
*.safetensors
*.bin
*.msgpack
*.fla
*.gguf
*.sft

# ======================================================================
# Runtime-generated experiment artifacts
# ======================================================================
logs/
outputs/
runs/
wandb/
lightning_logs/
events.out.tfevents.*

# ======================================================================
# Generated media / result figures
# ======================================================================
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.svg
*.mp4
*.webp
# (keep documentation assets if you add a docs/ folder)
!docs/**/*.png
!docs/**/*.jpg

# ======================================================================
# Archives & other large files
# ======================================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.gz
*.rar
*.7z
*.bz2
*.xz
*.npy
*.npz

# ======================================================================
# Temporary / debug stubs
# ======================================================================
.tv_stub/
*.tmp
*.temp
tmp/
temp/

# ======================================================================
# Python caches & build artifacts
# ======================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ======================================================================
# Testing & coverage
# ======================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ======================================================================
# Virtual environments & dependency managers
# ======================================================================
.venv/
venv/
env/
ENV/
.python-version
.conda/
conda-meta/

# ======================================================================
# Jupyter / IPython
# ======================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ======================================================================
# IDE / Editor / OS files
# ======================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ======================================================================
# Logs & databases
# ======================================================================
*.log
*.sqlite3
*.db
